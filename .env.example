# Copy to .env for local dev. On Render, set these in the dashboard env vars.
# NEVER commit the real .env.

# REQUIRED in deployment: any long random string. Without it the signing key
# is ephemeral and every restart invalidates all previously issued signatures
# (visible via GET /health -> "signing": "ephemeral").
WAYBILL_SIGNING_KEY_SEED=replace-with-a-long-random-string

# OPTIONAL: enables the LLM semantic check. Without it the service runs in
# deterministic keyword-only mode (fully functional).
WAYBILL_LLM_API_KEY=
# Defaults target Groq; for xAI Grok use https://api.x.ai/v1 and a grok model.
WAYBILL_LLM_BASE_URL=https://api.groq.com/openai/v1
WAYBILL_LLM_MODEL=llama-3.3-70b-versatile
